# Panacea Portal — environment variables
# Copy this file to `.env.local` and fill in the values for local development.
# Never commit `.env.local` or any file containing real secrets.

# ==================== CORE ====================
NODE_ENV=development

# Base URL of the backend API. Browser-exposed (NEXT_PUBLIC_ prefix) — base URL only, no secrets.
# Local development: http://localhost:4000/api
# Production: https://api.panacea.com/api (set in Netlify environment variables)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api

# ==================== MONITORING & ERROR TRACKING ====================
# Sentry (error tracking) — get DSN from https://sentry.io
# For development: leave empty or use test DSN
# For production: use the production DSN from Netlify environment variables
NEXT_PUBLIC_SENTRY_DSN=

# Log level: development | info | warn | error
NEXT_PUBLIC_LOG_LEVEL=info
