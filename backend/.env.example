# Panacea Portal Backend — Environment Variables
# Copy this file to .env.local and fill in the values for local development.
# Never commit .env.local or any file containing real secrets.

# Server
NODE_ENV=development
PORT=4000

# Database (PostgreSQL)
# Example: postgresql://postgres:password@localhost:5432/panacea_dev
# Set up a local PostgreSQL instance or use a managed service (AWS RDS, Railway, etc.)
DATABASE_URL=postgresql://postgres:password@localhost:5432/panacea_dev

# JWT Authentication
# Use a secure random string (min 32 chars) for production. Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=another-secret-for-refresh-tokens-min-32-chars

# File Storage (Cloudinary — added in Phase B5)
# Leave empty for now; will be used for medical records storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email Service (SendGrid — added in Phase B6)
# Leave empty for now; will be used for transactional emails (invites, password resets)
SENDGRID_API_KEY=

# Redis (Phase B4+ — real-time features and caching)
# Used for WebSocket connections, rate limiting, sessions, Bull job queue
# Local development: redis://localhost:6379
# Production/Upstash: redis://default:password@host:6379
REDIS_URL=

# Frontend Origin (for CORS)
# Matches panacea-portal .env.local NEXT_PUBLIC_API_BASE_URL origin
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=info
